# {{ nginx_frontend_domain }} — nginx stream SNI routing
# Managed by Ansible nginx_frontend role
#
# Reads SNI from TLS ClientHello (ssl_preread) and routes TCP:
{% if nginx_frontend_stream_v2_enabled | default(false) %}
#   {{ nginx_frontend_stream_v2_xhttp_sni }}    → Xray XHTTP v2+Reality   (127.0.0.1:{{ nginx_frontend_stream_v2_xhttp_port }})
#   {{ nginx_frontend_stream_v2_reality_sni }}  → Xray VLESS v2+Reality   (127.0.0.1:{{ nginx_frontend_stream_v2_reality_port }})
{% endif %}
{% if nginx_frontend_stream_fallback_enabled | default(false) %}
#   {{ nginx_frontend_stream_fallback_snis | join(', ') }}
#                                         → Xray VLESS fallback (multi-SNI) (127.0.0.1:{{ nginx_frontend_stream_fallback_port }})
{% endif %}
#   {{ nginx_frontend_domain }}           → nginx HTTPS              (127.0.0.1:{{ nginx_frontend_listen_port }})
#   default (other SNI)                   → tcp_close (immediate RST, no TLS response)
#
# This file is included inside stream {} block in nginx.conf

map $ssl_preread_server_name $sni_backend {
{% if nginx_frontend_stream_v2_enabled | default(false) %}
    {{ nginx_frontend_stream_v2_xhttp_sni }}    xhttp_reality_v2;
    {{ nginx_frontend_stream_v2_reality_sni }}  vless_reality_v2;
{% endif %}
{% if nginx_frontend_stream_fallback_enabled | default(false) %}
    {% for sni in nginx_frontend_stream_fallback_snis | default([]) %}
    {{ sni }}    vless_fallback;
    {% endfor %}
{% endif %}
{% if nginx_frontend_dashboard_enabled | default(false) %}
    {{ nginx_frontend_dashboard_sni }}      dashboard_https;
{% endif %}
{% if nginx_frontend_sub_enabled | default(false) %}
    {{ nginx_frontend_sub_sni }}            sub_https;
{% endif %}
    {{ nginx_frontend_domain }}             nginx_https;
    default                                 tcp_close;
}

# Default backend for unmatched SNI: connection refused — TCP open, then immediate RST.
# Equivalent to "return 444" in HTTP context (port 1 is reserved/never bound).
upstream tcp_close {
    server 127.0.0.1:1;
}

{% if nginx_frontend_stream_v2_enabled | default(false) %}
upstream xhttp_reality_v2 {
    server 127.0.0.1:{{ nginx_frontend_stream_v2_xhttp_port }};
}

upstream vless_reality_v2 {
    server 127.0.0.1:{{ nginx_frontend_stream_v2_reality_port }};
}

{% endif %}
{% if nginx_frontend_stream_fallback_enabled | default(false) %}
upstream vless_fallback {
    server 127.0.0.1:{{ nginx_frontend_stream_fallback_port }};
}

{% endif %}
upstream nginx_https {
    server 127.0.0.1:{{ nginx_frontend_listen_port }};
}

{% if nginx_frontend_dashboard_enabled | default(false) %}
upstream dashboard_https {
    server 127.0.0.1:{{ nginx_frontend_dashboard_port }};
}

{% endif %}
{% if nginx_frontend_sub_enabled | default(false) %}
upstream sub_https {
    server 127.0.0.1:{{ nginx_frontend_sub_port }};
}

{% endif %}
server {
    # Explicit accept backlog — nginx defaults this to 511 regardless of
    # net.core.somaxconn (65535 via srv_prepare), so a burst of SYN-less/empty
    # connections overflows it and drops real clients' SYNs. Same flood vector
    # the RU relay was hardened against (incident 2026-06-08); EU is the next
    # hop and equally exposed if its IP is hit directly.
    listen 443 reuseport backlog={{ nginx_frontend_listen_backlog | default(4096) }};
    proxy_pass $sni_backend;
    ssl_preread on;
    proxy_connect_timeout 10s;
    proxy_timeout 600s;
}
