# {{ nginx_frontend_sub_sni }} — fallback subscription endpoint (EU-direct, bypasses RU relay)
# Managed by Ansible nginx_frontend role
#
# Receives TLS from :443 stream (SNI-routed) → listens on :{{ nginx_frontend_sub_port }}.
# Validates Cloudflare origin secret. Exposes only /sub/fallback/ and /c/fallback/.
# Used as a stable fallback URL that clients add once during onboarding.

server {
    listen {{ nginx_frontend_sub_port }} ssl{{ '' if _nginx_has_http2_directive else ' http2' }};
{% if _nginx_has_http2_directive %}
    http2 on;
{% endif %}
    server_name {{ nginx_frontend_sub_sni }};

    ssl_certificate     /etc/nginx/ssl/dash.zirgate.com.crt;
    ssl_certificate_key /etc/nginx/ssl/dash.zirgate.com.key;

    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

{% if nginx_frontend_sub_cf_secret | default('') != '' %}
    # Reject requests that did not arrive through Cloudflare
    if ($http_x_origin_secret != "{{ nginx_frontend_sub_cf_secret }}") {
        return 403;
    }
{% endif %}

    location ~ ^/(sub|c)/fallback/ {
        proxy_pass          http://127.0.0.1:{{ nginx_frontend_raven_port }};
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_read_timeout  30s;
        proxy_connect_timeout 5s;
    }

{% if nginx_frontend_portal_enabled | default(true) %}
    # ── Phase 0 onboarding portal ───────────────────────────────────────────
    # /u/{token}        → Vue SPA (raven-dashboard frontend bundle)
    # /api/portal/me    → raven-dashboard backend (no JWT — sub_token in
    #                     query string is the auth, rate-limited per IP)
    # /assets/*, brand  → static assets the SPA pulls in
    #
    # The same Vue build is mounted on the admin dashboard vhost too;
    # vue-router internally matches /u/:token to the public Portal view
    # and short-circuits the auth-redirect.
    location /u/ {
        root  {{ nginx_frontend_dashboard_frontend_dir }};
        try_files /index.html =404;
    }

    location /api/portal/ {
        proxy_pass          http://127.0.0.1:{{ nginx_frontend_dashboard_backend_port }}/api/portal/;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_read_timeout  30s;
        proxy_connect_timeout 5s;
    }

    # SPA bundle assets — fingerprinted by Vite, safe to cache aggressively.
    location /assets/ {
        alias              {{ nginx_frontend_dashboard_frontend_dir }}/assets/;
        try_files          $uri =404;
        expires            1y;
        add_header         Cache-Control "public, immutable";
    }

    # Brand mark referenced directly from the portal page.
    location = /alchemylink-mark.png {
        alias              {{ nginx_frontend_dashboard_frontend_dir }}/alchemylink-mark.png;
        expires            7d;
    }
{% endif %}

    location / {
        return 404;
    }
}
