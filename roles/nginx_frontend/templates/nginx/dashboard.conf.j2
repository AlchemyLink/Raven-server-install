# {{ nginx_frontend_dashboard_sni }} — Raven Dashboard HTTPS frontend
# Managed by Ansible nginx_frontend role
#
# Receives TLS from :443 stream (SNI-routed) → listens on :{{ nginx_frontend_dashboard_port }}.
# Validates Cloudflare origin secret before proxying to raven-dashboard backend.
# Static Vue SPA served from {{ nginx_frontend_dashboard_frontend_dir }}.

server {
    listen {{ nginx_frontend_dashboard_port }} ssl{{ '' if _nginx_has_http2_directive else ' http2' }};
{% if _nginx_has_http2_directive %}
    http2 on;
{% endif %}
    server_name {{ nginx_frontend_dashboard_sni }};

    ssl_certificate     /etc/nginx/ssl/dash.zirgate.com.crt;
    ssl_certificate_key /etc/nginx/ssl/dash.zirgate.com.key;

    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

{% if nginx_frontend_dashboard_cf_secret != '' %}
    # Reject requests that did not arrive through Cloudflare
    if ($http_x_origin_secret != "{{ nginx_frontend_dashboard_cf_secret }}") {
        return 403;
    }
{% endif %}

    # ── Vue SPA static files ─────────────────────────────────────────────────
    root {{ nginx_frontend_dashboard_frontend_dir }};
    index index.html;

    # Screenshot assets referenced by broadcast templates. Explicit /screenshots/
    # location so missing files return 404 (the SPA fallback would otherwise
    # serve index.html for a missing image, breaking Telegram sendPhoto).
    location /screenshots/ {
        try_files $uri =404;
        add_header Cache-Control "public, max-age=86400";
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    # ── Raven Dashboard API + WebSocket ──────────────────────────────────────
    location /api/ {
        proxy_pass          http://127.0.0.1:{{ nginx_frontend_dashboard_backend_port }}/api/;
        proxy_set_header    Host              $host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;
        proxy_read_timeout  30s;
        proxy_connect_timeout 5s;
    }

    location /ws {
        proxy_pass          http://127.0.0.1:{{ nginx_frontend_dashboard_backend_port }}/ws;
        proxy_http_version  1.1;
        proxy_set_header    Upgrade    $http_upgrade;
        proxy_set_header    Connection "upgrade";
        proxy_set_header    Host       $host;
        proxy_read_timeout  3600s;
    }

    location /health {
        proxy_pass          http://127.0.0.1:{{ nginx_frontend_dashboard_backend_port }}/health;
        proxy_read_timeout  5s;
        proxy_connect_timeout 5s;
    }
}
