---
# Hysteria2 reserve secrets. Copy to secrets.yml and vault-encrypt:
#   cp roles/hysteria/defaults/secrets.yml.example roles/hysteria/defaults/secrets.yml
#   ansible-vault encrypt roles/hysteria/defaults/secrets.yml --vault-password-file vault_password.txt
# (secrets.yml is gitignored — never commit real values.)
hysteria_auth_password: "CHANGEME-auth-password"
hysteria_gecko_obfs_password: "CHANGEME-gecko-obfs-password"
hysteria_salamander_obfs_password: "CHANGEME-salamander-obfs-password"

# ── Publicly-trusted cert for the salamander instance (optional) ──────────────
# Set these to drop insecure=1/pinSHA256 from the client URI (the Xray engine
# deprecates allowInsecure in Aug-2026). Issues an LE cert via certbot DNS-01 over
# Cloudflare for a DEDICATED subdomain — accepts one CT-log entry for that name.
# Also set raven_subscribe_hysteria_cert_pin: "" and
# raven_subscribe_hysteria_sni: "<that domain>" in
# roles/raven_subscribe/defaults/secrets.yml so the URI matches the cert.
# hysteria_real_cert_enabled: true
# hysteria_cert_domain: "hy2.example.com"
# hysteria_certbot_email: "admin@example.com"
# hysteria_cloudflare_api_token: "..."   # Zone:DNS:Edit on the apex zone
