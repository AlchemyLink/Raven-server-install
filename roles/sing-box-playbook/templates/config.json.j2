{# templates/config.json.j2 - sing-box v1.12.21+ Configuration with Hysteria2 #}
{
  "log": {
    "disabled": {{ singbox_log_disabled | lower }},
    "level": "{{ singbox_log_level }}",
    "output": "{{ singbox_log_output }}",
    "timestamp": {{ singbox_log_timestamp | lower }}
  },

  "dns": {
    "servers": [
      {
        "type": "tls",
        "tag": "google",
        "server": "8.8.8.8",
        "server_port": 853
      },
      {
        "type": "tls",
        "tag": "cloudflare",
        "server": "1.1.1.1",
        "server_port": 853
      },
      {
        "type": "local",
        "tag": "local",
        "detour": "direct"
      }
    ],
    "strategy": "prefer_ipv4",
    "disable_cache": false,
    "disable_expire": false
  },

  "inbounds": [
    {% if singbox_hysteria2_enabled %}
    {
      "type": "hysteria2",
      "tag": "{{ singbox_hysteria2_tag }}",
      "listen": "{{ singbox_hysteria2_listen }}",
      "listen_port": {{ singbox_hysteria2_listen_port }},
      "up_mbps": {{ singbox_hysteria2_up_mbps }},
      "down_mbps": {{ singbox_hysteria2_down_mbps }},
      {% if singbox_hysteria2_users is defined and singbox_hysteria2_users | length > 0 %}
      "users": [
        {% for user in singbox_hysteria2_users %}
        {
          "name": "{{ user.name }}",
          "password": "{{ user.password }}"
        }{{ "," if not loop.last else "" }}
        {% endfor %}
      ],
      {% endif %}
      "obfs": {
        "type": "{{ singbox_hysteria2_obfs_type }}",
        "password": "{{ singbox_hysteria2_obfs_password }}"
      },
      "masquerade": "{{ singbox_hysteria2_masquerade }}",
      "tls": {
        "enabled": {{ singbox.tls_enabled | lower }},
        "server_name": "{{ singbox.tls_server_name }}",
        "alpn": [
          {% for alpn in singbox_tls_alpn %}
          "{{ alpn }}"{{ "," if not loop.last else "" }}
          {% endfor %}
        ],
        "min_version": "{{ singbox_tls_min_version }}",
        "max_version": "{{ singbox_tls_max_version }}",
        "acme": {
          "domain": ["{{ singbox.tls_acme_domain }}"],
          "data_directory": "{{ singbox.tls_acme_data_directory }}",
          "email": "{{ singbox.tls_acme_email }}",
          "provider": "{{ singbox.tls_acme_provider }}"
        }
      }
    }
    {% endif %}
  ],

  "outbounds": [
    {% for outbound in singbox_outbounds %}
    {
      "type": "{{ outbound.type }}",
      "tag": "{{ outbound.tag }}"
    }{{ "," if not loop.last else "" }}
    {% endfor %}
  ],

  "route": {
    "default_domain_resolver": "local",
    "rules": [
      {% if singbox_bypass_private_ip %}
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {% endif %}
      {% if singbox_bypass_ru_domains is defined and singbox_bypass_ru_domains | length > 0 %}
      {
        "domain_suffix": [
          {% for domain in singbox_bypass_ru_domains %}
          "{{ domain | regex_replace('^\*\.', '') }}"{{ "," if not loop.last else "" }}
          {% endfor %}
        ],
        "outbound": "direct"
      }{% endif %}
    ],
    "auto_detect_interface": true,
    "final": "direct"
  }
}
