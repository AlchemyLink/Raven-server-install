---
# Raven-dashboard secrets — copy to secrets.yml and encrypt:
#   ansible-vault encrypt roles/raven_dashboard/defaults/secrets.yml --vault-password-file vault_password.txt

# JWT signing key (required, min 32 chars)
# Generate: openssl rand -hex 32
raven_dashboard_jwt_secret: ""

# Raven-subscribe admin token (must match raven_subscribe_admin_token in raven_subscribe secrets)
raven_dashboard_raven_admin_token: ""

# X-Origin-Secret header value sent with dashboard → raven-subscribe API calls.
# Raven-subscribe validates this when proxied through Cloudflare.
# Generate: openssl rand -hex 32
raven_dashboard_raven_origin_secret: ""

# VictoriaMetrics basic auth credentials (must match monitoring role)
raven_dashboard_prometheus_user: ""
raven_dashboard_prometheus_password: ""
