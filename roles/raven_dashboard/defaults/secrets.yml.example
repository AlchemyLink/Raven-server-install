---
# Raven-dashboard secrets — copy to secrets.yml and encrypt:
#   ansible-vault encrypt roles/raven_dashboard/defaults/secrets.yml --vault-password-file vault_password.txt

# JWT signing key (required, min 32 chars)
# Generate: openssl rand -hex 32
raven_dashboard_jwt_secret: ""

# Raven-subscribe admin token (must match raven_subscribe_admin_token in raven_subscribe secrets)
raven_dashboard_raven_admin_token: ""

# X-Origin-Secret header value sent with dashboard → raven-subscribe API calls.
# Raven-subscribe validates this when proxied through Cloudflare.
# Generate: openssl rand -hex 32
raven_dashboard_raven_origin_secret: ""

# VictoriaMetrics basic auth credentials (must match monitoring role)
raven_dashboard_prometheus_user: ""
raven_dashboard_prometheus_password: ""

# Telegram bot token (optional). Create via @BotFather.
# Leave empty to disable the bot — dashboard works without it.
raven_dashboard_telegram_bot_token: ""

# External probe token — bearer for /api/external/probe-result, set on the
# offline RU mobile probe agent (scripts/ru-probe.sh) via X-Probe-Token.
# Leave empty to disable the endpoint (returns 401). Generate: openssl rand -hex 32.
raven_dashboard_external_probe_token: ""

# Telegram chat_ids that receive drift / staleness alerts from the external
# probe watcher. Leave empty to disable alerts (probes still ingest). Each
# chat_id must already be reachable by the bot — start a chat with the bot
# from each admin account first.
raven_dashboard_telegram_alert_chat_ids: []

# Pseudonymises email labels in PromQL queries so they match the labels emitted
# by xray-stats-exporter on EU and RU. MUST equal monitoring role's
# xray_stats_anonymize_secret — drift between the two desyncs every per-user
# dashboard. Leave empty when the exporter side is also unconfigured.
raven_dashboard_xray_stats_anonymize_secret: ""
