---
# Raven-subscribe secrets — copy to secrets.yml and encrypt:
#   ansible-vault encrypt roles/raven_subscribe/defaults/secrets.yml

# Admin token for Raven-subscribe API (required)
# Generate: openssl rand -hex 32
raven_subscribe_admin_token: ""

# Public URL used in subscription links — must be the relay domain (not direct EU IP)
# Example: "https://my.yourdomain.com"
raven_subscribe_base_url: "https://my.example.com"

# EU VPS public IP or domain (used in generated client outbound addresses)
raven_subscribe_server_host: ""

# Per-inbound host overrides (optional).
# Falls back to raven_subscribe_server_host when tag is not listed.
# Required when inbound SNI names differ from server_host.
# raven_subscribe_inbound_hosts:
#   vless-reality-in: "askubuntu.com"
#   vless-xhttp-in: "www.adobe.com"

# Per-inbound port overrides (optional).
# Falls back to the inbound's own port when tag is not listed.
# With SNI routing all protocols share port 443.
# raven_subscribe_inbound_ports:
#   vless-reality-in: 443
#   vless-xhttp-in: 443
#   vless-reality-v2-in: 443
#   vless-xhttp-v2-in: 443

# VLESS Encryption per-inbound override (optional).
# Only needed when inbound encryption keys differ — e.g. v1 and v2 inbounds use different keys.
# If omitted, xray_vless_client_encryption from xray secrets is applied to all inbounds uniformly.
# raven_subscribe_vless_client_encryption:
#   vless-reality-in: "mlkem768x25519plus.PublicKeyV1..."
#   vless-reality-v2-in: "mlkem768x25519plus.PublicKeyV2..."
