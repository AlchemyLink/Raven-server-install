{
  "listen_addr": "{{ raven_subscribe_listen_addr }}",
  "server_host": "{{ raven_subscribe_server_host }}",
  "config_dir": "{{ raven_subscribe_xray_config_dir }}",
  "db_path": "{{ raven_subscribe_db_dir }}/db.sqlite",
  "sync_interval_seconds": {{ raven_subscribe_sync_interval_seconds }},
  "base_url": "{{ raven_subscribe_base_url }}",
{% if raven_subscribe_fallback_base_url | default('') != '' %}
  "fallback_base_url": "{{ raven_subscribe_fallback_base_url }}",
{% endif %}
{% if raven_subscribe_fallback_server_host | default('') != '' %}
  "fallback_server_host": "{{ raven_subscribe_fallback_server_host }}",
{% endif %}
{% if raven_subscribe_fallback_inbound_hosts | default({}) | length > 0 %}
  "fallback_inbound_hosts": {{ raven_subscribe_fallback_inbound_hosts | to_json }},
{% endif %}
{% if raven_subscribe_fallback_inbound_tags | default([]) | length > 0 %}
  "fallback_inbound_tags": {{ raven_subscribe_fallback_inbound_tags | to_json }},
{% endif %}
  "admin_token": "{{ raven_subscribe_admin_token }}",
  "rate_limit_sub_per_min": {{ raven_subscribe_rate_limit_sub_per_min }},
  "rate_limit_admin_per_min": {{ raven_subscribe_rate_limit_admin_per_min }},
  "api_user_inbound_tag": "{{ raven_subscribe_api_inbound_tag }}",
  "xray_api_addr": "{{ raven_subscribe_xray_api_addr }}",
  "balancer_strategy": "{{ raven_subscribe_balancer_strategy }}",
  "balancer_probe_url": "{{ raven_subscribe_balancer_probe_url }}",
  "balancer_probe_interval": "{{ raven_subscribe_balancer_probe_interval }}",
  "xray_enabled": {{ raven_subscribe_xray_enabled | lower }},
  "inbound_hosts": {{ raven_subscribe_inbound_hosts | default({}) | to_json }},
{% if raven_subscribe_client_dns_servers | default([]) | length > 0 %}
  "client_dns_servers": {{ raven_subscribe_client_dns_servers | to_json }},
{% endif %}
{% if raven_subscribe_client_blackhole_response | default('') != '' %}
  "client_blackhole_response": "{{ raven_subscribe_client_blackhole_response }}",
{% endif %}
  "inbound_ports": {{ raven_subscribe_inbound_ports | to_json }},
  "static_inbounds": [],
  "bridge_api_addr": "{{ raven_subscribe_bridge_api_addr | default('') }}",
  "bridge_transparent_tags": {{ raven_subscribe_bridge_transparent_tags | default({}) | to_json }}
{#
  vless_client_encryption: prefer explicit raven_subscribe_vless_client_encryption if set,
  otherwise auto-build from xray_vless_client_encryption (loaded via xray secrets vars_file).
  Supports per-inbound override via raven_subscribe_vless_client_encryption map.
#}
{%- set ns = namespace(enc_map=raven_subscribe_vless_client_encryption | default({})) -%}
{%- if ns.enc_map | length == 0 and xray_vless_client_encryption is defined and xray_vless_client_encryption != '' -%}
  {%- set _tags = xray_inbound_tags | default({}) -%}
  {%- set ns.enc_map = {
    (_tags.vless_reality_v2_in | default('vless-reality-v2-in')): xray_vless_client_encryption,
    (_tags.vless_xhttp_v2_in   | default('vless-xhttp-v2-in')):   xray_vless_client_encryption,
  } -%}
{%- endif -%}
{#- Add isolated fallback VLESS Encryption for vless-fallback-in tag. -#}
{%- if xray_vless_fallback_client_encryption is defined and xray_vless_fallback_client_encryption != '' -%}
  {%- set _fb_tag = (xray_fallback.tag | default('vless-fallback-in')) if xray_fallback is defined else 'vless-fallback-in' -%}
  {%- set _ = ns.enc_map.update({_fb_tag: xray_vless_fallback_client_encryption}) -%}
{%- endif -%}
{% if ns.enc_map | length > 0 %},
  "vless_client_encryption": {{ ns.enc_map | to_json }}{% endif %}
}
