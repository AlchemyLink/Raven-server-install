{
  "outbounds": [
    {
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "{{ xray_bridge_eu_host }}",
            "port": {{ xray_bridge_eu_port }},
            "users": [
              {
                "id": "{{ xray_bridge_eu_user_id }}",
                "encryption": "none",
                "flow": "xtls-rprx-vision",
                "level": 0
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "realitySettings": {
          "serverName": "{{ xray_bridge_eu_xhttp_sni }}",
          "publicKey": "{{ xray_bridge_eu_reality_public_key }}",
          "shortId": "{{ xray_bridge_eu_reality_short_id }}",
          "fingerprint": "{{ xray_bridge_eu_fingerprint | default('chrome') }}"
        },
        "xhttpSettings": {
          "mode": "{{ xray_bridge_eu_xhttp_mode }}",
          "path": "{{ xray_bridge_eu_xhttp_path }}",
          "host": "{{ xray_bridge_eu_xhttp_sni }}"
        }
      },
      "tag": "{{ xray_bridge_tag_out }}"
    },
    {
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIPv4"
      },
      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "settings": {},
      "tag": "blocked"
    }
  ]
}
