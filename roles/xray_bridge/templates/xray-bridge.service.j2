[Unit]
Description=Xray Bridge Service (RU chain proxy)
Documentation=https://xtls.github.io/documents/
# WireGuard must be up before xray-bridge binds to 10.10.0.2 — without this,
# xray-bridge fails with "bind: cannot assign requested address" on boot.
After=network.target nss-lookup.target wg-quick@wg0.service
Wants=wg-quick@wg0.service

[Service]
User={{ xray_bridge_user }}
Group={{ xray_bridge_group }}
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ExecStart={{ xray_bridge_bin_dir }}/xray run -confdir {{ xray_bridge_config_dir }}config.d
Restart=on-failure
RestartSec=3s
RestartPreventExitStatus=23
TimeoutStopSec=30s
LimitNPROC=2000
LimitNOFILE=1000000

[Install]
WantedBy=multi-user.target
