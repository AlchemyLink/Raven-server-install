---
# xray_bridge secrets — copy to secrets.yml and encrypt:
#   ansible-vault encrypt roles/xray_bridge/defaults/secrets.yml

# Bridge Reality keys — generate with: xray x25519
xray_bridge_reality:
  private_key: "BridgePrivateKeyHere"
  public_key:  "BridgePublicKeyHere"
  spiderX: "/"
  short_id:
    - "bridgeShortIdHere"

# Bridge users — can share UUIDs with EU xray_users
xray_bridge_users:
  - id: "UUID_1"
    flow: "xtls-rprx-vision"
    email: "user1@example.com"

# EU Xray connection details
xray_bridge_eu_host: "EU_VPS_IP"             # Direct IP of EU VPS (not via RU relay)
xray_bridge_eu_reality_public_key: "EU_PublicKeyHere"   # From EU xray_reality.public_key
xray_bridge_eu_reality_short_id: "EU_ShortIdHere"       # From EU xray_reality.short_id[0]
xray_bridge_eu_user_id: "BRIDGE_USER_UUID"  # Dedicated UUID registered on EU Xray XHTTP inbound
