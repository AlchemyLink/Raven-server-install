---
# Copy to secrets.yml and encrypt with ansible-vault:
#   ansible-vault encrypt roles/relay/defaults/secrets.yml

relay_domain: "your-ru-domain.com"        # Domain pointing to RU VPS (A record → RU IP)
relay_sub_my: "my.your-ru-domain.com"     # Subdomain for Raven relay (A record → RU IP)
relay_upstream_host: "1.2.3.4"            # EU server IP address
relay_certbot_email: "admin@example.com"  # Email for Let's Encrypt notifications

# Optional: Cloudflare Origin CA cert for {{ relay_sub_my }} (CF-proxied subdomain).
# When set, nginx serves this cert instead of LE for the my.* server block.
# Issued from CF dashboard → SSL/TLS → Origin Server with SAN: *.<domain> + <domain>.
# CF Origin CA is trusted only by Cloudflare's edge, never by browsers — safe to
# use here because traffic to {{ relay_sub_my }} always goes through CF proxy.
# Benefit: {{ relay_sub_my }} never appears in public CT logs, just CF's wildcard.
# Validity is typically 15 years and CF doesn't auto-renew — set a calendar reminder.
# relay_cf_origin_cert: |
#   <full PEM block from CF dashboard, including BEGIN/END CERTIFICATE markers>
# relay_cf_origin_key: |
#   <full PEM block — shown only at issue time, save it then>
