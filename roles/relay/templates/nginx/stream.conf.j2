# {{ relay_domain }} — nginx stream SNI routing
# Managed by Ansible relay role
#
# Reads SNI from TLS ClientHello (ssl_preread) and routes TCP:
#   {{ relay_domain }}     → local nginx HTTPS (127.0.0.1:{{ relay_https_port }}) for stub site
#   {{ relay_sub_my }}     → local nginx HTTPS (127.0.0.1:{{ relay_https_port }}) for Raven relay
{% if relay_bridge_enabled | default(false) and relay_bridge_sni != '' %}
#   {{ relay_bridge_sni }}     → local Xray bridge (127.0.0.1:{{ relay_bridge_port }}) — chain proxy
{% endif %}
{% if relay_transparent_enabled | default(false) %}
#   {{ relay_transparent_reality_sni }}    → xray-bridge transparent :{{ relay_transparent_reality_port }} (EU Reality)
#   {{ relay_transparent_xhttp_sni }}      → xray-bridge transparent :{{ relay_transparent_xhttp_port }} (EU XHTTP)
#   {{ relay_transparent_reality_v2_sni }} → xray-bridge transparent :{{ relay_transparent_reality_v2_port }} (EU Reality v2)
#   {{ relay_transparent_xhttp_v2_sni }}   → xray-bridge transparent :{{ relay_transparent_xhttp_v2_port }} (EU XHTTP v2)
{% endif %}
#   everything else (VPN)  → EU server ({{ relay_upstream_host }}:{{ relay_upstream_port }})
#
# PROXY protocol: only on upstreams to local Xray (127.0.0.1).
# Do NOT add proxy_protocol to eu_vpn — EU expects raw TCP without PROXY.
#
# This file is included inside stream {} block in nginx.conf

{% if relay_stream_enabled %}
# Per-source-IP concurrent-connection cap. Stops a single IP from exhausting nginx's
# accept queue (incident 2026-06-08: one IP held 400+ empty SNI-less connections for 30s
# each → listen backlog overflowed → real clients' SYNs dropped → content failed to load).
# Lives in stream{} context (this file is included there).
limit_conn_zone $binary_remote_addr zone=relay_perip:10m;
{% if relay_access_log | default(false) %}
# First-hop observability (client → RU). Privacy-preserving: NO client IP logged.
# Only SNI + session_time (short sessions = TSPU killing the stream mid-flight)
# + status + upstream + byte counts. Lets us see Reality-vs-XHTTP first-hop drops.
log_format relay_sni '$ssl_preread_server_name sess=$session_time status=$status '
                     'up=$upstream_addr in=$bytes_received out=$bytes_sent proto=$protocol';
{% endif %}
map $ssl_preread_server_name $relay_backend {
    {{ relay_domain }}     local_https;
    {{ relay_sub_my }}     local_https;
{% if relay_bridge_enabled | default(false) and relay_bridge_sni != '' %}
    {{ relay_bridge_sni }} xray_bridge;
{% endif %}
{% if relay_transparent_enabled | default(false) %}
    {{ relay_transparent_reality_sni }}    xray_bridge_reality;
    {{ relay_transparent_xhttp_sni }}      xray_bridge_xhttp;
    {{ relay_transparent_reality_v2_sni }} xray_bridge_reality_v2;
    {{ relay_transparent_xhttp_v2_sni }}   xray_bridge_xhttp_v2;
{% endif %}
    default                eu_vpn;
}

upstream local_https {
    server 127.0.0.1:{{ relay_https_port }};
}

{% if relay_bridge_enabled | default(false) and relay_bridge_sni != '' %}
upstream xray_bridge {
    server 127.0.0.1:{{ relay_bridge_port }};
}

{% endif %}
{% if relay_transparent_enabled | default(false) %}
upstream xray_bridge_reality {
    server 127.0.0.1:{{ relay_transparent_reality_port }};
}

upstream xray_bridge_xhttp {
    server 127.0.0.1:{{ relay_transparent_xhttp_port }};
}

upstream xray_bridge_reality_v2 {
    server 127.0.0.1:{{ relay_transparent_reality_v2_port }};
}

upstream xray_bridge_xhttp_v2 {
    server 127.0.0.1:{{ relay_transparent_xhttp_v2_port }};
}

{% endif %}
upstream eu_vpn {
    server {{ relay_upstream_host }}:{{ relay_upstream_port }};
}

{% for fwd in relay_hysteria_udp_forwards | default([]) %}
# Hysteria2 UDP reserve forward ({{ fwd.note | default('') }}) — relay :{{ fwd.port }}/udp → EU
upstream hy_udp_{{ fwd.port }} {
    server {{ fwd.upstream }};
}
server {
    listen {{ fwd.port }} udp reuseport;
    proxy_pass hy_udp_{{ fwd.port }};
    proxy_timeout {{ fwd.timeout | default('120s') }};
}
{% endfor %}
server {
    listen 443 reuseport backlog={{ relay_listen_backlog | default(4096) }};
    proxy_pass $relay_backend;
    ssl_preread on;
    # Cap concurrent connections per source IP (CGNAT-tolerant ceiling; xmux uses ~16-32
    # per client). A flooder is bounded here instead of overrunning the whole listener.
    limit_conn relay_perip {{ relay_limit_conn_per_ip | default(128) }};
    proxy_connect_timeout 10s;
    proxy_timeout 600s;
{% if relay_access_log | default(false) %}
    access_log /var/log/nginx/relay-sni.log relay_sni;
{% else %}
    access_log off;
{% endif %}
}
{% endif %}
