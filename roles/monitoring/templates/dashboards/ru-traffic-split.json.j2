{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 10,
      "title": "Обзор — RU Bridge",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "green", "mode": "fixed"},
          "mappings": [
            {"options": {"0": {"color": "red", "text": "DOWN"}, "1": {"color": "green", "text": "UP"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "xray_up{job=\"xray-bridge-stats\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Bridge status",
      "type": "stat"
    },

    {
      "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 10, "x": 4, "y": 1},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "sum(rate(xray_inbound_uplink_bytes_total{job=\"xray-bridge-stats\"}[$__rate_interval])) + sum(rate(xray_inbound_downlink_bytes_total{job=\"xray-bridge-stats\"}[$__rate_interval]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Bridge throughput (сейчас)",
      "type": "stat"
    },

    {
      "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 10, "x": 14, "y": 1},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "sum(increase(xray_inbound_uplink_bytes_total{job=\"xray-bridge-stats\"}[$__range])) + sum(increase(xray_inbound_downlink_bytes_total{job=\"xray-bridge-stats\"}[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Bridge трафик за период",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 20,
      "title": "Пользователи через bridge",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 6},
      "id": 21,
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull", "max"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "rate(xray_user_uplink_bytes_total{job=\"xray-bridge-stats\"}[$__rate_interval])",
          "legendFormat": "{% raw %}{{email}}{% endraw %}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Upload через bridge (bytes/s by user)",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 16},
      "id": 22,
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull", "max"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "rate(xray_user_downlink_bytes_total{job=\"xray-bridge-stats\"}[$__rate_interval])",
          "legendFormat": "{% raw %}{{email}}{% endraw %}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Download через bridge (bytes/s by user)",
      "type": "timeseries"
    },

    {
      "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 26},
      "id": 23,
      "options": {"orientation": "horizontal", "displayMode": "gradient", "reduceOptions": {"calcs": ["lastNotNull"]}, "valueMode": "color", "showUnfilled": true},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "sort_desc(increase(xray_user_downlink_bytes_total{job=\"xray-bridge-stats\"}[$__range]))",
          "instant": true,
          "legendFormat": "{% raw %}{{email}}{% endraw %}",
          "refId": "A"
        }
      ],
      "title": "Download через bridge за период (топ)",
      "type": "bargauge"
    },

    {
      "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 26},
      "id": 24,
      "options": {"orientation": "horizontal", "displayMode": "gradient", "reduceOptions": {"calcs": ["lastNotNull"]}, "valueMode": "color", "showUnfilled": true},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "sort_desc(increase(xray_user_uplink_bytes_total{job=\"xray-bridge-stats\"}[$__range]))",
          "instant": true,
          "legendFormat": "{% raw %}{{email}}{% endraw %}",
          "refId": "A"
        }
      ],
      "title": "Upload через bridge за период (топ)",
      "type": "bargauge"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36},
      "id": 30,
      "title": "EU vs Bridge — суммарный трафик",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 37},
      "id": 31,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "mean", "max"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "sum(rate(xray_inbound_uplink_bytes_total{job=\"xray-stats\"}[$__rate_interval])) + sum(rate(xray_inbound_downlink_bytes_total{job=\"xray-stats\"}[$__rate_interval]))",
          "legendFormat": "EU (direct)",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "sum(rate(xray_inbound_uplink_bytes_total{job=\"xray-bridge-stats\"}[$__rate_interval])) + sum(rate(xray_inbound_downlink_bytes_total{job=\"xray-bridge-stats\"}[$__rate_interval]))",
          "legendFormat": "RU Bridge",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Суммарный трафик: EU прямые подключения vs RU Bridge (bytes/s)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 47},
      "id": 40,
      "title": "DPI индикаторы — Bridge",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 48},
      "id": 41,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "sum"]}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "rate(xray_handshake_failure_total{job=\"xray-bridge-stats\"}[$__rate_interval])",
          "legendFormat": "{% raw %}{{inbound}}{% endraw %} handshake failures",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "rate(xray_connection_reset_total{job=\"xray-bridge-stats\"}[$__rate_interval])",
          "legendFormat": "{% raw %}{{inbound}}{% endraw %} TCP RST",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "rate(xray_probe_detected_total{job=\"xray-bridge-stats\"}[$__rate_interval])",
          "legendFormat": "{% raw %}{{inbound}}{% endraw %} active probes",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "DPI события на bridge (events/s)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 58},
      "id": 50,
      "title": "RU Direct — топ назначений",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
      "description": "Доля трафика, уходящего напрямую с RU (не через цепочку на EU). Метрика: xray_outbound_requests_total{job=\"xray-bridge\"}.",
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "blue", "mode": "fixed"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.3},
              {"color": "red", "value": 0.7}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 59},
      "id": 51,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "(sum(xray_outbound_requests_total{job=\"xray-bridge\",outbound=~\"direct.*\"}) or vector(0)) / clamp_min(sum(xray_outbound_requests_total{job=\"xray-bridge\"}) or vector(0), 1)",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Доля direct-трафика (RU bridge)",
      "type": "stat"
    },

    {
      "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
      "description": "Топ-10 IP-назначений через RU bridge за выбранный диапазон. xray-exporter парсит access.log, который не содержит разбивку по outbound — показан весь трафик bridge (direct + chain-out-eu).",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "inspect": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [
              {"id": "displayName", "value": "Запросов"},
              {"id": "custom.width", "value": 120}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "target"},
            "properties": [{"id": "displayName", "value": "Назначение (IP)"}]
          }
        ]
      },
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 63},
      "id": 52,
      "options": {
        "footer": {"show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Запросов"}]
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "{{ grafana_prometheus_datasource_uid }}"},
          "editorMode": "code",
          "expr": "topk(10, sum by (target) (increase(xray_requested_domain_ip_total{job=\"xray-bridge\"}[$__range])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Топ-10 назначений (RU bridge, все outbound, за период)",
      "transformations": [
        {"id": "filterFieldsByName", "options": {"include": {"names": ["target", "Value"]}}}
      ],
      "type": "table"
    }

  ],
  "refresh": "30s",
