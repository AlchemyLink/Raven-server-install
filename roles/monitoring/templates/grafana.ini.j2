[server]
http_addr = {{ grafana_listen.split(':')[0] }}
http_port = {{ grafana_listen.split(':')[1] }}
# Grafana binds to the DO VPC private IP (not 127.0.0.1). This lets EU
# vmagent scrape /metrics over the private network and keeps the public
# IP free of any Grafana login form. Operator access is via SSH tunnel:
#   ssh -L 13000:{{ grafana_listen }} -p 2200 konkov@<mon-public-ip>
# Then open http://localhost:13000 in browser.

[security]
admin_user = admin
admin_password = {{ grafana_admin_password }}
disable_initial_admin_creation = false
cookie_secure = false        # SSH tunnel is localhost, no HTTPS needed here
cookie_samesite = lax
secret_key = {{ grafana_admin_password | hash('sha256') }}

[auth.anonymous]
enabled = false

[auth]
disable_login_form = false

[users]
allow_sign_up = false
allow_org_create = false

[log]
mode = file
level = warn

[paths]
data = {{ grafana_data_dir }}
logs = {{ grafana_log_dir }}
provisioning = {{ grafana_provisioning_dir }}

[analytics]
reporting_enabled = false
check_for_updates = false

[metrics]
# Expose Prometheus-format metrics at /metrics (process stats, alert engine,
# request counts). Scraped by EU vmagent via private VPC.
enabled = true
