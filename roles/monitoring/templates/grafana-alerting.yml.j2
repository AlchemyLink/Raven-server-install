apiVersion: 1

groups:
  - orgId: 1
    name: raven-critical
    folder: Raven
    interval: 1m
    rules:

      - uid: xray-down
        title: "Xray API недоступен"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "xray_up{job=\"xray-stats\"}"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: lt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: Alerting
        execErrState: Alerting
        for: 2m
        annotations:
          summary: "Xray API не отвечает на gRPC запросы"
          description: "xray_up == 0 уже более 2 минут. Сервис Xray может быть упавшим."
        labels:
          severity: critical

      - uid: raven-subscribe-down
        title: "Raven-subscribe недоступен"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "up{job=\"raven-subscribe\"}"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: lt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: Alerting
        execErrState: Alerting
        for: 2m
        annotations:
          summary: "Raven-subscribe не отвечает на /health"
          description: "Сервис raven-subscribe недоступен более 2 минут. Подписки не работают."
        labels:
          severity: critical

      - uid: eu-server-down
        title: "EU сервер недоступен"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "up{job=\"node\", server=\"eu\"}"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: lt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: Alerting
        execErrState: Alerting
        for: 3m
        annotations:
          summary: "EU сервер ({{ monitoring_eu_host }}) недоступен"
          description: "node_exporter на EU сервере не отвечает более 3 минут."
        labels:
          severity: critical

      - uid: ru-server-down
        title: "RU сервер недоступен"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "up{job=\"node\", server=\"ru\"}"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: lt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: Alerting
        execErrState: Alerting
        for: 3m
        annotations:
          summary: "RU сервер ({{ monitoring_ru_host }}) недоступен"
          description: "node_exporter на RU сервере не отвечает более 3 минут."
        labels:
          severity: warning

      - uid: inbound-probe-down
        title: "Inbound недоступен (blackbox probe)"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "probe_success{job=~\"blackbox_.*\"} == 0"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: lt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: NoData
        execErrState: Alerting
        for: 2m
        annotations:
          summary: "{% raw %}Inbound {{ $labels.inbound }} (SNI: {{ $labels.sni }}) не отвечает{% endraw %}"
          description: "{% raw %}TCP+TLS handshake к {{ $labels.instance }} провален более 2 минут. Inbound или nginx могут быть упавшими.{% endraw %}"
        labels:
          severity: critical

      - uid: eu-disk-high
        title: "EU диск заполнен >85%"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "1 - node_filesystem_avail_bytes{server=\"eu\", mountpoint=\"/\"} / node_filesystem_size_bytes{server=\"eu\", mountpoint=\"/\"}"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [0.85]
                    type: gt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: NoData
        execErrState: Error
        for: 5m
        annotations:
          summary: "EU диск заполнен более чем на 85%"
          description: "Дисковое пространство на EU сервере критически мало. Могут перестать писаться логи."
        labels:
          severity: warning

  - orgId: 1
    name: raven-fallback
    folder: Raven
    interval: 1m
    rules:

      # Fallback Model A invariant: enabled=true is the steady state, false only
      # during short sanitization windows. Fires when the flag stays off for 2h —
      # catches the forgotten-rollback pattern (killswitch 2026-04-30, fallback
      # 2026-06-07..09) before users accumulate days of 403s.
      - uid: fallback-disabled-stuck
        title: "Fallback выключен дольше 2 часов"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "raven_fallback_enabled"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: lt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: NoData
        execErrState: Error
        for: 2h
        annotations:
          summary: "Глобальный fallback-флаг выключен более 2 часов"
          description: "raven_fallback_enabled == 0 дольше окна санации. По Decision Fallback Model A steady state = enabled. Все /sub/fallback/* отвечают 403, killswitch держит fallback-инбаунд вне рантайма Xray. Включить: дашборд Emergency или POST /api/fallback/enable."
        labels:
          severity: warning

      # User impact: clients actually hitting the disabled fallback. Low threshold —
      # during the 2026-06-09 incident there were ~27 denials/day across 8 users.
      - uid: fallback-denied-requests
        title: "Пользователи получают 403 на fallback-подписке"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 1800
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "sum(increase(raven_fallback_denied_total[30m]))"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [3]
                    type: gt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: OK
        execErrState: Error
        for: 5m
        annotations:
          summary: "Fallback-подписка отдаёт 403 реальным клиентам"
          description: "Более 3 отклонённых fallback-запросов за 30 минут при выключенном глобальном флаге. Клиенты с fallback-URL не могут обновить подписку (инцидент 2026-06-09). Если санация не идёт прямо сейчас — включить fallback."
        labels:
          severity: warning

  - orgId: 1
    name: raven-dpi
    folder: Raven
    interval: 1m
    rules:

      - uid: dpi-handshake-spike
        title: "DPI: всплеск ошибок TLS handshake"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "sum(increase(xray_handshake_failure_total[5m]))"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [10]
                    type: gt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: OK
        execErrState: Error
        for: 2m
        annotations:
          summary: "Всплеск TLS handshake failures — возможна DPI-блокировка"
          description: "Более 10 TLS handshake failures за 5 минут. Промежуточный DPI может активно обрывать соединения. Проверьте дашборд DPI Detection."
        labels:
          severity: warning

      - uid: dpi-probe-detected
        title: "DPI: обнаружен активный probe"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "sum(increase(xray_probe_detected_total[5m]))"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: gt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: OK
        execErrState: Error
        for: 1m
        annotations:
          summary: "Обнаружен активный DPI probe на инбаунде"
          description: "Получены нетипичные данные (garbage TLS record, unexpected ALPN, i/o timeout). Признак активного DPI-зондирования."
        labels:
          severity: critical

      - uid: dpi-rst-spike
        title: "DPI: всплеск TCP RST"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "sum(increase(xray_connection_reset_total[5m]))"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [20]
                    type: gt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: OK
        execErrState: Error
        for: 2m
        annotations:
          summary: "Массовые TCP RST — возможна инжекция RST со стороны DPI"
          description: "Более 20 connection reset за 5 минут. Промежуточный DPI может инжектировать TCP RST пакеты. Проверьте blackbox probe_success."
        labels:
          severity: warning

      - uid: dpi-degradation-sustained
        title: "DPI: устойчивая деградация пропускной способности"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 3600
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "sum(increase(xray_throughput_degradation_total[1h]))"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [100]
                    type: gt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: OK
        execErrState: Error
        for: 10m
        annotations:
          summary: "Устойчивая деградация трафика на инбаундах"
          description: "Более 100 событий деградации пропускной способности за час. Возможно DPI-ограничение или перегрузка канала."
        labels:
          severity: warning

      - uid: raven-probe-sni-blocked
        title: "raven-probe: SNI блокируется с RU vantage"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 900
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "max by (vantage, name, sni, verdict) (raven_probe_verdict{verdict=~\"TLS_BLOCK|TLS_RESET|TLS_DROP|TCP_RESET|DNS_BLOCK\",name=~\"eu_.*\"} == 1)"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [0.5]
                    type: gt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: OK
        execErrState: Error
        for: 15m
        annotations:
          summary: "SNI {% raw %}{{ $labels.sni }}{% endraw %} блокируется с {% raw %}{{ $labels.vantage }}{% endraw %} ({% raw %}{{ $labels.verdict }}{% endraw %})"
          description: "raven-probe видит верdict={% raw %}{{ $labels.verdict }}{% endraw %} для path {% raw %}{{ $labels.vantage }}{% endraw %}→EU с cover-SNI {% raw %}{{ $labels.sni }}{% endraw %} 15+ минут. Path-specific DPI или PIN-DC-style egress block. Compare with isp_* probes for same SNI to confirm path-vs-ISP."
        labels:
          severity: warning

      - uid: raven-probe-all-cover-blocked
        title: "raven-probe: меньше 2 рабочих cover SNI с vantage"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 1800
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "count by (vantage) (raven_probe_verdict{verdict=\"OK\",name=~\"eu_.*\"} == 1)"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [2]
                    type: lt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: Alerting
        execErrState: Alerting
        for: 30m
        annotations:
          summary: "raven-probe {% raw %}{{ $labels.vantage }}{% endraw %}: меньше 2 рабочих cover-SNI"
          description: "Из всех cover-SNI на пути к EU работает меньше 2. Это критично: VPN из этой vantage скорее всего сломан для большинства клиентов. Проверьте egress DPI и срочно эскалируйте."
        labels:
          severity: critical
