apiVersion: 1

groups:
  - orgId: 1
    name: raven-critical
    folder: Raven
    interval: 1m
    rules:

      - uid: xray-down
        title: "Xray API недоступен"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "xray_up{job=\"xray-stats\"}"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: lt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: Alerting
        execErrState: Alerting
        for: 2m
        annotations:
          summary: "Xray API не отвечает на gRPC запросы"
          description: "xray_up == 0 уже более 2 минут. Сервис Xray может быть упавшим."
        labels:
          severity: critical

      - uid: raven-subscribe-down
        title: "Raven-subscribe недоступен"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "up{job=\"raven-subscribe\"}"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: lt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: Alerting
        execErrState: Alerting
        for: 2m
        annotations:
          summary: "Raven-subscribe не отвечает на /health"
          description: "Сервис raven-subscribe недоступен более 2 минут. Подписки не работают."
        labels:
          severity: critical

      - uid: eu-server-down
        title: "EU сервер недоступен"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "up{job=\"node\", server=\"eu\"}"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: lt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: Alerting
        execErrState: Alerting
        for: 3m
        annotations:
          summary: "EU сервер ({{ monitoring_eu_host }}) недоступен"
          description: "node_exporter на EU сервере не отвечает более 3 минут."
        labels:
          severity: critical

      - uid: ru-server-down
        title: "RU сервер недоступен"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "up{job=\"node\", server=\"ru\"}"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: lt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: Alerting
        execErrState: Alerting
        for: 3m
        annotations:
          summary: "RU сервер ({{ monitoring_ru_host }}) недоступен"
          description: "node_exporter на RU сервере не отвечает более 3 минут."
        labels:
          severity: warning

      - uid: inbound-probe-down
        title: "Inbound недоступен (blackbox probe)"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "probe_success{job=~\"blackbox_.*\"} == 0"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: lt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: NoData
        execErrState: Alerting
        for: 2m
        annotations:
          summary: "{% raw %}Inbound {{ $labels.inbound }} (SNI: {{ $labels.sni }}) не отвечает{% endraw %}"
          description: "{% raw %}TCP+TLS handshake к {{ $labels.instance }} провален более 2 минут. Inbound или nginx могут быть упавшими.{% endraw %}"
        labels:
          severity: critical

      - uid: eu-disk-high
        title: "EU диск заполнен >85%"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "1 - node_filesystem_avail_bytes{server=\"eu\", mountpoint=\"/\"} / node_filesystem_size_bytes{server=\"eu\", mountpoint=\"/\"}"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [0.85]
                    type: gt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: NoData
        execErrState: Error
        for: 5m
        annotations:
          summary: "EU диск заполнен более чем на 85%"
          description: "Дисковое пространство на EU сервере критически мало. Могут перестать писаться логи."
        labels:
          severity: warning

  - orgId: 1
    name: raven-tspu
    folder: Raven
    interval: 1m
    rules:

      - uid: tspu-handshake-spike
        title: "TSPU: всплеск ошибок TLS handshake"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "sum(increase(xray_handshake_failure_total[5m]))"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [10]
                    type: gt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: OK
        execErrState: Error
        for: 2m
        annotations:
          summary: "Всплеск TLS handshake failures — возможна TSPU блокировка"
          description: "Более 10 TLS handshake failures за 5 минут. TSPU может активно обрывать соединения. Проверьте дашборд TSPU Detection."
        labels:
          severity: warning

      - uid: tspu-probe-detected
        title: "TSPU: обнаружен активный probe"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "sum(increase(xray_probe_detected_total[5m]))"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [1]
                    type: gt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: OK
        execErrState: Error
        for: 1m
        annotations:
          summary: "Обнаружен активный DPI probe на инбаунде"
          description: "Получены нетипичные данные (garbage TLS record, unexpected ALPN, i/o timeout). Это признак активного зондирования TSPU."
        labels:
          severity: critical

      - uid: tspu-rst-spike
        title: "TSPU: всплеск TCP RST"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "sum(increase(xray_connection_reset_total[5m]))"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [20]
                    type: gt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: OK
        execErrState: Error
        for: 2m
        annotations:
          summary: "Массовые TCP RST — возможна инжекция RST от TSPU"
          description: "Более 20 connection reset за 5 минут. TSPU может инжектировать TCP RST пакеты. Проверьте blackbox probe_success."
        labels:
          severity: warning

      - uid: tspu-degradation-sustained
        title: "TSPU: устойчивая деградация пропускной способности"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 3600
              to: 0
            datasourceUid: "{{ grafana_prometheus_datasource_uid }}"
            model:
              expr: "sum(increase(xray_throughput_degradation_total[1h]))"
              instant: true
              refId: A
          - refId: C
            datasourceUid: __expr__
            model:
              type: threshold
              refId: C
              conditions:
                - evaluator:
                    params: [100]
                    type: gt
                  operator:
                    type: and
                  query:
                    params: [A]
                  reducer:
                    type: last
        noDataState: OK
        execErrState: Error
        for: 10m
        annotations:
          summary: "Устойчивая деградация трафика на инбаундах"
          description: "Более 100 событий деградации пропускной способности за час. Возможна TSPU-ограничение или перегрузка канала."
        labels:
          severity: warning
