global:
  scrape_interval: {{ victoriametrics_scrape_interval }}
  scrape_timeout: {{ victoriametrics_scrape_timeout }}
  external_labels:
    donor: "{{ monitoring_donor_label }}"

scrape_configs:
  - job_name: xray
    metrics_path: {{ xray_exporter_metrics_path }}
    static_configs:
      - targets:
          - {{ xray_exporter_listen }}
    # Drop xray_requested_domain_ip_total entirely — its `target` label is the
    # raw destination IP a user connected to. Storing this in VM (which lives
    # on RU and is at seizure risk) leaks per-user browsing history. The
    # metric is unused by any active dashboard since the bridge decommission.
    metric_relabel_configs:
      - source_labels: [__name__]
        regex: 'xray_requested_domain_ip_total'
        action: drop

  - job_name: xray-stats
    metrics_path: {{ xray_stats_exporter_metrics_path }}
    static_configs:
      - targets:
          - {{ xray_stats_exporter_listen }}
    # Drop sub-country geo precision before metrics leave EU. country/city
    # remain on xray_user_last_country (for the geo-overview panel), but
    # without lat/lon a seized RU TSDB can't pin a user to a city block.
    # labeldrop applies to all metrics in this scrape — only this exporter
    # ever emits lat/lon, so the regex is unambiguous.
    metric_relabel_configs:
      - regex: '(lat|lon)'
        action: labeldrop

  - job_name: node
    static_configs:
      - targets:
          - {{ node_exporter_listen }}
        labels:
          server: eu
          instance: "{{ hostvars['vm_my_srv']['ansible_host'] }}"
{% for h in groups['ru'] %}
      - targets:
          - {{ hostvars[h].wg_ip | default(wg_ru_ip) }}:9100
        labels:
          server: ru
          instance: "{{ hostvars[h].ansible_host }}"
{% endfor %}
{% for h in groups['mon'] %}
      - targets:
          - {{ hostvars[h].private_ip }}:9100
        labels:
          server: mon
          instance: "{{ hostvars[h].ansible_host }}"
{% endfor %}

  # vmagent self-scrape — primary defense against silent monitoring outages.
  # If vmagent stops scraping or pushing, no other metrics flow either.
  - job_name: vmagent
    static_configs:
      - targets:
          - 127.0.0.1:8429
        labels:
          server: eu
          instance: "{{ hostvars['vm_my_srv']['ansible_host'] }}"

  # VictoriaMetrics self-metrics on MON — process health, ingestion rate,
  # query latency, disk usage. Auth required (httpAuth flag in VM service unit).
  - job_name: victoriametrics
    basic_auth:
      username: "{{ victoriametrics_auth_username }}"
      password: "{{ victoriametrics_auth_password }}"
    static_configs:
      - targets:
          - {{ hostvars[groups['mon'][0]].private_ip }}:8428
        labels:
          server: mon
          instance: "{{ hostvars[groups['mon'][0]].ansible_host }}"

  # raven-dashboard app metrics: raven_users_total/active, http_responses,
  # worker_last_tick_age_seconds (broadcast/quota/sync background workers),
  # schema_version, goroutines, mem stats.
  - job_name: raven-dashboard
    static_configs:
      - targets:
          - 127.0.0.1:8090
        labels:
          server: eu
          instance: "{{ hostvars['vm_my_srv']['ansible_host'] }}"

  # Grafana self-metrics: alert engine state, datasource request counts,
  # http handlers, Go runtime. Scraped via DO VPC private network.
  - job_name: grafana
    static_configs:
      - targets:
          - {{ hostvars[groups['mon'][0]].private_ip }}:13000
        labels:
          server: mon
          instance: "{{ hostvars[groups['mon'][0]].ansible_host }}"

  # nginx-prometheus-exporter on RU — request count, accepts, connections by
  # state (active/reading/writing/waiting). Reads nginx stub_status locally.
  # Scraped over WireGuard.
{% for h in groups['ru'] %}
  - job_name: nginx-{{ h }}
    static_configs:
      - targets:
          - {{ hostvars[h].wg_ip | default(wg_ru_ip) }}:9113
        labels:
          server: ru
          instance: "{{ hostvars[h].ansible_host }}"
{% endfor %}

  # raven-probe — layered Reality-aware connectivity probe (DNS/TCP/TLS/HTTP)
  # per cover-SNI from each RU vantage. Detects path-specific DPI (PIN DC vs
  # Beget pattern), ISP-wide SNI blocks, DNS poisoning. Scraped via WG.
{% for h in groups['ru'] %}
  - job_name: raven-probe-{{ h }}
    static_configs:
      - targets:
          - {{ hostvars[h].wg_ip | default(wg_ru_ip) }}:9117
        labels:
          server: ru
          instance: "{{ hostvars[h].ansible_host }}"
{% endfor %}

{% for probe in blackbox_inbound_probes %}
  # Blackbox probe: {{ probe.name }} ({{ probe.sni }})
  - job_name: "blackbox_{{ probe.name }}"
    metrics_path: /probe
    params:
      module: ["tcp_tls_{{ probe.name | replace('-', '_') }}"]
      target: ["{{ probe.target }}"]
    static_configs:
      - targets:
          - {{ blackbox_listen }}
        labels:
          inbound: "{{ probe.name }}"
          server: "{{ probe.server }}"
          sni: "{{ probe.sni }}"
    relabel_configs:
      - target_label: instance
        replacement: "{{ probe.target }}"
{% endfor %}

  # Blackbox HTTP probe: raven-subscribe /health
  - job_name: "blackbox_raven-subscribe"
    metrics_path: /probe
    params:
      module: ["http_2xx"]
      target: ["http://{{ raven_subscribe_scrape_addr }}/health"]
    static_configs:
      - targets:
          - {{ blackbox_listen }}
        labels:
          instance: "raven-subscribe"
    relabel_configs:
      - target_label: instance
        replacement: "raven-subscribe"
