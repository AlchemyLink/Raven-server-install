global:
  scrape_interval: {{ victoriametrics_scrape_interval }}
  scrape_timeout: {{ victoriametrics_scrape_timeout }}
  external_labels:
    donor: "{{ monitoring_donor_label }}"

# RU-local exporters only.
# EU exporters (xray, xray-stats, node-eu, blackbox) are scraped by
# vmagent on EU VPS and pushed here via /api/v1/write over WireGuard.
scrape_configs:
  - job_name: node
    static_configs:
{% for h in groups['ru'] %}
      - targets:
          - {{ hostvars[h].wg_ip | default(wg_ru_ip) }}:9100
        labels:
          server: ru
          instance: "{{ hostvars[h].ansible_host }}"
{% endfor %}
