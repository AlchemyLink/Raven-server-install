[Unit]
Description=NGINX Prometheus Exporter
Documentation=https://github.com/nginx/nginx-prometheus-exporter
After=network.target nginx.service
Requires=nginx.service

[Service]
Type=simple
User=nobody
Group=nogroup
NoNewPrivileges=true
ExecStart={{ nginx_exporter_bin_dir }}/nginx-prometheus-exporter \
  --web.listen-address={{ nginx_exporter_listen }} \
  --nginx.scrape-uri=http://127.0.0.1:{{ nginx_stub_status_port }}/stub_status
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
