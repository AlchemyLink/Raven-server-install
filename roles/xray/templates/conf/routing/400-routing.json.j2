  {
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {% if xray_blocked_domains | length > 0 %}
      {
        "type": "field",
        "domain": [
          {% for domain in xray_blocked_domains %}
          "{{ domain }}"{{ "," if not loop.last }}
          {% endfor %}
        ],
        "outboundTag": "blocked"
      },
      {% endif %}
      {% if xray_api.enable %}
      {
        "type": "field",
        "inboundTag": ["{{ xray_api.inbound.tag }}"],
        "outboundTag": "{{ xray_api.inbound.tag }}"
      },
      {% endif %}
      {% if xray_direct_ru_enabled | default(true) %}
      {
        "type": "field",
        "domain": [
          "geosite:category-gov-ru",
          {% for domain in xray_direct_ru_domains | default([]) %}
          "{{ domain }}",
          {% endfor %}
          "domain:ru",
          "domain:su",
          "domain:рф"
        ],
        "outboundTag": "direct-ru"
      },
      {
        "type": "field",
        "ip": [
          "geoip:ru",
          "geoip:private"
        ],
        "outboundTag": "direct-ru"
      },
      {% endif %}
      {
        "type": "field",
        "inboundTag": [
          "{{ xray_common.inbound_tag.vless_reality_in }}",
          "{{ xray_common.inbound_tag.vless_xhttp_in }}"{% if xray_v2_inbounds_enabled | default(false) %},
          "{{ xray_common.inbound_tag.vless_reality_v2_in }}",
          "{{ xray_common.inbound_tag.vless_xhttp_v2_in }}"{% endif %}
        ],
        "outboundTag": "freedom"
      }
    ]
  }
}    