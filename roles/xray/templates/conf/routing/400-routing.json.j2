  {
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "inboundTag": [
          {% for key, value in xray_common.inbound_tag.items() %}
            "{{ value }}"{{ "," if not loop.last }}
          {% endfor %}
        ],
        "outboundTag": "freedom"
        },
      {
        "type": "field",
        "domain": [
          {% for domain in xray_blocked_domains %}
          "{{ domain }}"{{ "," if not loop.last }}
          {% endfor %}
        ],
        "outboundTag": "blocked"
      }
      {% if xray_api.enable %}
      ,
      {
        "type": "field",
        "inboundTag": ["{{ xray_api.inbound.tag }}"],
        "outboundTag": "{{ xray_api.inbound.tag }}"
      }
      {% endif %}
    ]
  }
}    