{
  "inbounds": [
    {
      "tag": "{{ xray_common.inbound_tag.vless_reality_in }}",
      "settings": {
        "clients": [          
          {% for user in xray_users %}
          {
            "id": "{{ user.id }}",
            "flow": "{{ user.flow | default('xtls-rprx-vision') }}",
            "email": "{{ user.email | default('') }}",
            "level": 0
          }{{ "," if not loop.last }}
          {% endfor %}
        ],
        "decryption": "{{ xray_vless_decryption | default('none') }}"
      }
    }
  ]
}