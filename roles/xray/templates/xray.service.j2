[Unit]
Description=Xray Service
Documentation=https://xtls.github.io/documents/
After=network.target nss-lookup.target

[Service]
User={{ xray_user }}
Group={{ xray_group }}
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ExecStart={{ xray_install_dir }}/xray run -confdir {{ xray_config_dir }}config.d
Restart=on-failure
RestartSec=3s
RestartPreventExitStatus=23
TimeoutStopSec=30s
LimitNPROC=2000
LimitNOFILE=1000000

# Filesystem hardening
# ProtectSystem=strict makes /usr /boot /efi /etc /var read-only by default.
# ReadWritePaths carves out the log directory.
# Config in /etc/xray/ is intentionally read-only for the process.
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths={{ xray_log_dir }}

# Device and kernel hardening
PrivateDevices=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true
ProtectHostname=true
ProtectClock=true

# Process hardening
RestrictRealtime=true
RestrictSUIDSGID=true
LockPersonality=true

# Syscall filter — @system-service covers all syscalls a well-behaved
# Go service needs; @network-io adds socket/recv/send calls.
SystemCallFilter=@system-service @network-io
SystemCallArchitectures=native
SystemCallErrorNumber=EPERM

[Install]
WantedBy=multi-user.target
