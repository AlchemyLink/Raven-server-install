# Secrets — never commit real credentials
vault_password.txt
**/secrets.yml
**/secrets.yaml
**/*_secrets.yml
**/vault_password.txt
**/*.secret
**/*.vault

.vscode
.ansible
roles/hosts.yml
roles/*/inventory.ini

# Vagrant
.vagrant/
vagrant/inventory/

# Generated by tests/run.sh
tests/.cache/
tests/.output/
tests/fixtures/test_secrets.yml

# Test artifacts that may contain inventory data (IPs, hostnames).
# Ad-hoc scripts produce timestamped result files at tests/ root —
# never commit them, they're regenerable by re-running the script.
tests/*_results_*
tests/*.log
tests/output/


CLAUDE.md

# Internal ops notes — runbooks, ADRs, threat models, dependency maps.
# Useful next to the code locally, but their content (specific failure modes,
# fragility maps, IPs/SNIs in plaintext) is higher-value to an attacker than
# to a public reader. Keep them out of the public mirror.
docs/