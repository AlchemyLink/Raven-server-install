#!/usr/bin/env bash
# git pre-push: stdin lines are "<local_ref> <local_sha> <remote_ref> <remote_sha>"
checker="$(git rev-parse --show-toplevel)/scripts/check-sensitive-data.sh"
zero='0000000000000000000000000000000000000000'
status=0
while read -r local_ref local_sha remote_ref remote_sha; do
    [ "$local_sha" = "$zero" ] && continue          # branch deletion
    if [ "$remote_sha" = "$zero" ]; then
        range="$local_sha"                          # new branch — scan everything
    else
        range="${remote_sha}..${local_sha}"
    fi
    "$checker" --push "$range" || status=$?
done
exit "$status"
